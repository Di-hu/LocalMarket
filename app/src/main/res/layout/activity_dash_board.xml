<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">


    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/img_3"/>


    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80000000"/>


    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/bottomNav">

        <LinearLayout
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">


            <TextView
                android:id="@+id/tvGreeting"
                android:text="Welcome"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>


            <EditText
                android:id="@+id/searchEt"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_search"
                android:hint="Search medicines..."
                android:textColor="@android:color/white"
                android:textColorHint="#CCCCCC"
                android:padding="16dp"

                android:imeOptions="actionSearch"
                android:inputType="text"/>


            <GridLayout
                android:layout_marginTop="24dp"
                android:columnCount="2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <!-- Medicines Card -->
                <LinearLayout
                    android:id="@+id/cardMedicines"
                    android:layout_margin="8dp"
                    android:layout_width="0dp"
                    android:layout_columnWeight="1"
                    android:layout_height="200dp"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="140dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/img_4"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:gravity="center"
                        android:text="Medicines"
                        android:textColor="@android:color/white"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:background="#1E1E1E"/>
                </LinearLayout>



                <LinearLayout
                    android:id="@+id/cardDoctor"
                    android:layout_margin="8dp"
                    android:layout_width="0dp"
                    android:layout_columnWeight="1"
                    android:layout_height="200dp"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="140dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/img_5"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:gravity="center"
                        android:text="Consult Doctor"
                        android:textColor="@android:color/white"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:background="#1E1E1E"/>
                </LinearLayout>



                <LinearLayout
                    android:id="@+id/cardPharmacy"
                    android:layout_margin="8dp"
                    android:layout_width="0dp"
                    android:layout_columnWeight="1"
                    android:layout_height="200dp"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="140dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/img_6"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:gravity="center"
                        android:text="Pharmacies"
                        android:textColor="@android:color/white"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:background="#1E1E1E"/>
                </LinearLayout>



                <LinearLayout
                    android:id="@+id/cardHealth"
                    android:layout_margin="8dp"
                    android:layout_width="0dp"
                    android:layout_columnWeight="1"
                    android:layout_height="200dp"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="140dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/img_8"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:gravity="center"
                        android:text="Health Tips"
                        android:textColor="@android:color/white"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:background="#1E1E1E"/>
                </LinearLayout>

            </GridLayout>

        </LinearLayout>

    </ScrollView>


    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_alignParentBottom="true"
        android:layout_width="match_parent"
        android:layout_height="65dp"
        android:orientation="horizontal"
        android:weightSum="4"
        android:background="#121212"
        android:elevation="12dp">


    </LinearLayout>

</RelativeLayout>